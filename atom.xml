</span><span class='line'>&#9;&#9;&#9;rs = stmt.executeQuery(sql);
</span><span class='line'>&#9;&#9;&#9;out.print("查询结果：");
</span><span class='line'>&#9;&#9;&#9;out.print("&lt;br /&gt;");
</span><span class='line'>&#9;&#9;&#9;out.println("姓名"+"  "+"性别 "+"  "+"年龄");
</span><span class='line'>&#9;&#9;&#9;out.print("&lt;br /&gt;");
</span><span class='line'>&#9;&#9;&#9;while (rs.next()) {
</span><span class='line'>&#9;&#9;&#9;&#9;out.println(rs.getString("id")+"   &nbsp  "+rs.getString("name")+"  &nbsp "+rs.getInt("val")); //将查询结果输出
</span><span class='line'>&#9;&#9;&#9;&#9;out.print("&lt;br /&gt;");
