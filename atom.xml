</span><span class='line'>&#9;&#9;&#9;break;
</span><span class='line'>&#9;&#9;err = m-&gt;op-&gt;show(m, p);
</span><span class='line'>
</span><span class='line'>&#9;&#9;if (err &lt; 0)
</span><span class='line'>&#9;&#9;&#9;break;
